### Routing via cells section   ###
# Plus via rule, metals are along the prefered direction
VIA L1M1_PR DEFAULT
  LAYER mcon ;
  RECT -0.0114 -0.0114 0.0114 0.0114 ;
  LAYER li1 ;
  RECT -0.0114 -0.0114 0.0114 0.0114 ;
  LAYER met1 ;
  RECT -0.0194 -0.0154 0.0194 0.0154 ;
END L1M1_PR

VIARULE L1M1_PR GENERATE
  LAYER li1 ;
  ENCLOSURE 0 0 ;
  LAYER met1 ;
  ENCLOSURE 0.0080 0.0040 ;
  LAYER mcon ;
  RECT -0.0114 -0.0114 0.0114 0.0114 ;
  SPACING 0.0481 BY 0.0481 ;
END L1M1_PR

# Plus via rule, metals are along the non prefered direction
VIA L1M1_PR_R DEFAULT
  LAYER mcon ;
  RECT -0.0114 -0.0114 0.0114 0.0114 ;
  LAYER li1 ;
  RECT -0.0114 -0.0114 0.0114 0.0114 ;
  LAYER met1 ;
  RECT -0.0154 -0.0194 0.0154 0.0194 ;
END L1M1_PR_R

VIARULE L1M1_PR_R GENERATE
  LAYER li1 ;
  ENCLOSURE 0 0 ;
  LAYER met1 ;
  ENCLOSURE 0.0040 0.0080 ;
  LAYER mcon ;
  RECT -0.0114 -0.0114 0.0114 0.0114 ;
  SPACING 0.0481 BY 0.0481 ;
END L1M1_PR_R

# Minus via rule, lower layer metal is along prefered direction
VIA L1M1_PR_M DEFAULT
  LAYER mcon ;
  RECT -0.0114 -0.0114 0.0114 0.0114 ;
  LAYER li1 ;
  RECT -0.0114 -0.0114 0.0114 0.0114 ;
  LAYER met1 ;
  RECT -0.0154 -0.0194 0.0154 0.0194 ;
END L1M1_PR_M

VIARULE L1M1_PR_M GENERATE
  LAYER li1 ;
  ENCLOSURE 0 0 ;
  LAYER met1 ;
  ENCLOSURE 0.0040 0.0080 ;
  LAYER mcon ;
  RECT -0.0114 -0.0114 0.0114 0.0114 ;
  SPACING 0.0481 BY 0.0481 ;
END L1M1_PR_M

# Minus via rule, upper layer metal is along prefered direction
VIA L1M1_PR_MR DEFAULT
  LAYER mcon ;
  RECT -0.0114 -0.0114 0.0114 0.0114 ;
  LAYER li1 ;
  RECT -0.0114 -0.0114 0.0114 0.0114 ;
  LAYER met1 ;
  RECT -0.0194 -0.0154 0.0194 0.0154 ;
END L1M1_PR_MR

VIARULE L1M1_PR_MR GENERATE
  LAYER li1 ;
  ENCLOSURE 0 0 ;
  LAYER met1 ;
  ENCLOSURE 0.0080 0.0040 ;
  LAYER mcon ;
  RECT -0.0114 -0.0114 0.0114 0.0114 ;
  SPACING 0.0481 BY 0.0481 ;
END L1M1_PR_MR

# Centered via rule, we really do not want to use it
VIA L1M1_PR_C DEFAULT
  LAYER mcon ;
  RECT -0.0114 -0.0114 0.0114 0.0114 ;
  LAYER li1 ;
  RECT -0.0114 -0.0114 0.0114 0.0114 ;
  LAYER met1 ;
  RECT -0.0194 -0.0194 0.0194 0.0194 ;
END L1M1_PR_C

