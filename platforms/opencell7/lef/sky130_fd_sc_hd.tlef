  ENCLOSURE ABOVE 0.0086 0.0086 ; # Met0.534522 0.400892
  ANTENNADIFFAREARATIO PWL ( ( 0 6 ) ( 0.0125 6 ) ( 0.0225 6.81 ) ( 22.5 816 ) ) ;
