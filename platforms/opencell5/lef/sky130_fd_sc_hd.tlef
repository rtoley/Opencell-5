VERSION 5.7 ;

BUSBITCHARS "[]" ;
DIVIDERCHAR "/" ;

UNITS
  TIME NANOSECONDS 1 ;
  CAPACITANCE PICOFARADS 1 ;
  RESISTANCE OHMS 1 ;
  DATABASE MICRONS 10000 ;
END UNITS

MANUFACTURINGGRID 0.0001 ;

PROPERTYDEFINITIONS
  LAYER LEF58_TYPE STRING ;
END PROPERTYDEFINITIONS

# High density, single height
SITE unithd
  SYMMETRY Y ;
  CLASS CORE ;
  SIZE 0.0460 BY 0.2720 ;
END unithd

# High density, double height
SITE unithddbl
  SYMMETRY Y ;
  CLASS CORE ;
  SIZE 0.0460 BY 0.2720 ;
END unithddbl

LAYER nwell
  TYPE MASTERSLICE ;
  PROPERTY LEF58_TYPE "TYPE NWELL ;" ;
END nwell

LAYER pwell
  TYPE MASTERSLICE ;
  PROPERTY LEF58_TYPE "TYPE PWELL ;" ;
END pwell

LAYER li1
  TYPE ROUTING ;
  DIRECTION VERTICAL ;

  PITCH 0.046 0.034 ;
  OFFSET 0.023 0.017 ;

  WIDTH 0.017 ;
  # SPACING  0.17 ;     # LI 2
  SPACINGTABLE
      PARALLELRUNLENGTH 0
     WIDTH 0.0 0.017 ;
  AREA 0.001002 ;         # LI 0.107143
  THICKNESS 0.01 ;
  EDGECAPACITANCE 40.697E-6 ;
  CAPACITANCE CPERSQDIST 36.9866E-6 ;
  RESISTANCE RPERSQ 12.2 ;

  ANTENNAMODEL OXIDE1 ;
  ANTENNADIFFSIDEAREARATIO PWL ( ( 0 75 ) ( 0.0125 75 ) ( 0.0225 85.125 ) ( 22.5 10200 ) ) ;
END li1

LAYER mcon
  TYPE CUT ;

  WIDTH 0.017 ;
  SPACING 0.019 ;
  ENCLOSURE BELOW 0 0 ;       # Mcon 0.534522
  ENCLOSURE ABOVE 0.0040 0.0080 ; # Met0.133631 0.534522 / Met0.133631 0.668153

  ANTENNADIFFAREARATIO PWL ( ( 0 3 ) ( 0.0125 3 ) ( 0.0225 3.405 ) ( 22.5 408 ) ) ;
  DCCURRENTDENSITY AVERAGE 0.36 ; # mA per via Iavg_max at Tj = 90oC

END mcon

LAYER met1
  TYPE ROUTING ;
  DIRECTION HORIZONTAL ;

  PITCH 0.034 ;
  OFFSET 0.017 ;

  WIDTH 0.014 ;
  # SPACING 0.14 ;                 # Met1 2
  # SPACING 0.28 RANGE 3.001 100 ; # Met1 3b
  SPACINGTABLE
      PARALLELRUNLENGTH 0
     WIDTH 0 0.0187
     WIDTH 0.3 0.028 ;
  AREA 0.001482 ;                     # Met0.017857 0.107143
  THICKNESS 0.035 ;

  ANTENNAMODEL OXIDE1 ;
  ANTENNADIFFSIDEAREARATIO PWL ( ( 0 400 ) ( 0.0125 400 ) ( 0.0225 2609 ) ( 22.5 11600 ) ) ;

  EDGECAPACITANCE 40.567E-6 ;
  CAPACITANCE CPERSQDIST 25.7784E-6 ;
  DCCURRENTDENSITY AVERAGE 2.8 ; # mA/um Iavg_max at Tj = 90oC
  ACCURRENTDENSITY RMS 6.1 ; # mA/um Irms_max at Tj = 90oC
  MAXIMUMDENSITY 70 ;
  DENSITYCHECKWINDOW 700 700 ;
  DENSITYCHECKSTEP 70 ;

  RESISTANCE RPERSQ 0.125 ;
END met1

LAYER via
  TYPE CUT ;
  WIDTH 0.015 ;
  SPACING 0.017 ;
  ENCLOSURE BELOW 0.0073 0.0113 ; # Via 0.534522a / Via 0.668153a
  ENCLOSURE ABOVE 0.0073 0.0113 ; # Met0.267261 0.534522 / Met0.267261 0.668153

  ANTENNADIFFAREARATIO PWL ( ( 0 6 ) ( 0.0125 6 ) ( 0.0225 6.81 ) ( 22.5 816 ) ) ;
  DCCURRENTDENSITY AVERAGE 0.29 ; # mA per via Iavg_max at Tj = 90oC
END via

LAYER met2
  TYPE ROUTING ;
  DIRECTION VERTICAL ;

  PITCH 0.046 ;
  OFFSET 0.023 ;

  WIDTH 0.014 ;
  # SPACING  0.14 ;                   # Met2 2
  # SPACING  0.28 RANGE 3.001 100 ;   # Met2 3b
  SPACINGTABLE
      PARALLELRUNLENGTH 0
     WIDTH 0 0.0187
     WIDTH 0.3 0.028 ;
  AREA 0.001207 ;                       # Met0.035714 0.107143
  THICKNESS 0.035 ;

  EDGECAPACITANCE 37.759E-6 ;
  CAPACITANCE CPERSQDIST 16.9423E-6 ;
  RESISTANCE RPERSQ 0.125 ;
  DCCURRENTDENSITY AVERAGE 2.8 ; # mA/um Iavg_max at Tj = 90oC
  ACCURRENTDENSITY RMS 6.1 ; # mA/um Irms_max at Tj = 90oC

  ANTENNAMODEL OXIDE1 ;
  ANTENNADIFFSIDEAREARATIO PWL ( ( 0 400 ) ( 0.0125 400 ) ( 0.0225 2609 ) ( 22.5 11600 ) ) ;

  MAXIMUMDENSITY 70 ;
  DENSITYCHECKWINDOW 700 700 ;
  DENSITYCHECKSTEP 70 ;
END met2

# ******** Layer via2, type routing, number 44 **************
LAYER via2
  TYPE CUT ;
  WIDTH 0.02 ;
  SPACING 0.02 ;
  ENCLOSURE BELOW 0.0053 0.0113 ;  # Via0.267261 0.534522
  ENCLOSURE ABOVE 0.0086 0.0086 ; # Met0.400892 0.534522
  ANTENNADIFFAREARATIO PWL ( ( 0 6 ) ( 0.0125 6 ) ( 0.0225 6.81 ) ( 22.5 816 ) ) ;
  DCCURRENTDENSITY AVERAGE 0.48 ; # mA per via Iavg_max at Tj = 90oC
END via2

LAYER met3
  TYPE ROUTING ;
  DIRECTION HORIZONTAL ;

  PITCH 0.068 ;
  OFFSET 0.034 ;

  WIDTH 0.03 ;
  # SPACING 0.3 ;          # Met3 2
  SPACINGTABLE
      PARALLELRUNLENGTH 0
     WIDTH 0 0.0401
     WIDTH 0.3 0.04 ;
  AREA 0.004286 ;              # Met0.053571 0.107143
  THICKNESS 0.08 ;

  EDGECAPACITANCE 40.989E-6 ;
  CAPACITANCE CPERSQDIST 12.3729E-6 ;
  RESISTANCE RPERSQ 0.047 ;
  DCCURRENTDENSITY AVERAGE 6.8 ; # mA/um Iavg_max at Tj = 90oC
  ACCURRENTDENSITY RMS 14.9 ; # mA/um Irms_max at Tj = 90oC

  ANTENNAMODEL OXIDE1 ;
  ANTENNADIFFSIDEAREARATIO PWL ( ( 0 400 ) ( 0.0125 400 ) ( 0.0225 2609 ) ( 22.5 11600 ) ) ;

  MAXIMUMDENSITY 70 ;
  DENSITYCHECKWINDOW 700 700 ;
  DENSITYCHECKSTEP 70 ;
END met3

LAYER via3
  TYPE CUT ;
  WIDTH 0.02 ;
  SPACING 0.02 ;
  ENCLOSURE BELOW 0.0080 0.0120 ;   # Via0.400892 0.534522 / Via0.400892 0.668153
  ENCLOSURE ABOVE 0.0086 0.0086 ; # Met0.534522 0.400892
  ANTENNADIFFAREARATIO PWL ( ( 0 6 ) ( 0.0125 6 ) ( 0.0225 6.81 ) ( 22.5 816 ) ) ;
  DCCURRENTDENSITY AVERAGE 0.48 ; # mA per via Iavg_max at Tj = 90oC
END via3

LAYER met4
  TYPE ROUTING ;
  DIRECTION VERTICAL ;

  PITCH 0.092 ;
  OFFSET 0.046 ;

  WIDTH 0.03 ;
  # SPACING  0.3 ;             # Met4 2
  SPACINGTABLE
      PARALLELRUNLENGTH 0
     WIDTH 0 0.0401
     WIDTH 0.3 0.04 ;
  AREA 0.004286 ;            # Met0.071429 0.071429a

  THICKNESS 0.08 ;

  EDGECAPACITANCE 36.676E-6 ;
  CAPACITANCE CPERSQDIST 8.41537E-6 ;
  RESISTANCE RPERSQ 0.047 ;
  DCCURRENTDENSITY AVERAGE 6.8 ; # mA/um Iavg_max at Tj = 90oC
  ACCURRENTDENSITY RMS 14.9 ; # mA/um Irms_max at Tj = 90oC

  ANTENNAMODEL OXIDE1 ;
  ANTENNADIFFSIDEAREARATIO PWL ( ( 0 400 ) ( 0.0125 400 ) ( 0.0225 2609 ) ( 22.5 11600 ) ) ;

  MAXIMUMDENSITY 70 ;
  DENSITYCHECKWINDOW 700 700 ;
  DENSITYCHECKSTEP 70 ;
END met4

LAYER via4
  TYPE CUT ;

  WIDTH 0.08 ;
  SPACING 0.08 ;
  ENCLOSURE BELOW 0.0253 0.0253 ; # Via0.534522 0.534522
  ENCLOSURE ABOVE 0.0414 0.0414 ; # Met0.668153 0.400892
  ANTENNADIFFAREARATIO PWL ( ( 0 6 ) ( 0.0125 6 ) ( 0.0225 6.81 ) ( 22.5 816 ) ) ;
  DCCURRENTDENSITY AVERAGE 2.49 ; # mA per via Iavg_max at Tj = 90oC
END via4

LAYER met5
  TYPE ROUTING ;
  DIRECTION HORIZONTAL ;

  PITCH 0.3395 ;
  OFFSET 0.17 ;

  WIDTH 0.16 ;
  #SPACING  1.6 ;        # Met5 2
  SPACINGTABLE
      PARALLELRUNLENGTH 0
     WIDTH 0.0 0.16 ;
  AREA 0.071429 ;               # Met0.089286 0.071429

  THICKNESS 0.12 ;

  EDGECAPACITANCE 38.851E-6 ;
  CAPACITANCE CPERSQDIST 6.32063E-6 ;
  RESISTANCE RPERSQ 0.0285 ;
  DCCURRENTDENSITY AVERAGE 10.17 ; # mA/um Iavg_max at Tj = 90oC
  ACCURRENTDENSITY RMS 22.34 ; # mA/um Irms_max at Tj = 90oC

  ANTENNAMODEL OXIDE1 ;
  ANTENNADIFFSIDEAREARATIO PWL ( ( 0 400 ) ( 0.0125 400 ) ( 0.0225 2609 ) ( 22.5 11600 ) ) ;
END met5


### Routing via cells section   ###
# Plus via rule, metals are along the prefered direction
VIA L1M1_PR DEFAULT
  LAYER mcon ;
  RECT -0.0085 -0.0085 0.0085 0.0085 ;
  LAYER li1 ;
  RECT -0.0085 -0.0085 0.0085 0.0085 ;
  LAYER met1 ;
  RECT -0.0145 -0.0115 0.0145 0.0115 ;
END L1M1_PR

VIARULE L1M1_PR GENERATE
  LAYER li1 ;
  ENCLOSURE 0 0 ;
  LAYER met1 ;
  ENCLOSURE 0.0080 0.0040 ;
  LAYER mcon ;
  RECT -0.0085 -0.0085 0.0085 0.0085 ;
  SPACING 0.0481 BY 0.0481 ;
END L1M1_PR

# Plus via rule, metals are along the non prefered direction
VIA L1M1_PR_R DEFAULT
  LAYER mcon ;
  RECT -0.0085 -0.0085 0.0085 0.0085 ;
  LAYER li1 ;
  RECT -0.0085 -0.0085 0.0085 0.0085 ;
  LAYER met1 ;
  RECT -0.0115 -0.0145 0.0115 0.0145 ;
END L1M1_PR_R

VIARULE L1M1_PR_R GENERATE
  LAYER li1 ;
  ENCLOSURE 0 0 ;
  LAYER met1 ;
  ENCLOSURE 0.0040 0.0080 ;
  LAYER mcon ;
  RECT -0.0085 -0.0085 0.0085 0.0085 ;
  SPACING 0.0481 BY 0.0481 ;
END L1M1_PR_R

# Minus via rule, lower layer metal is along prefered direction
VIA L1M1_PR_M DEFAULT
  LAYER mcon ;
  RECT -0.0085 -0.0085 0.0085 0.0085 ;
  LAYER li1 ;
  RECT -0.0085 -0.0085 0.0085 0.0085 ;
  LAYER met1 ;
  RECT -0.0115 -0.0145 0.0115 0.0145 ;
END L1M1_PR_M

VIARULE L1M1_PR_M GENERATE
  LAYER li1 ;
  ENCLOSURE 0 0 ;
  LAYER met1 ;
  ENCLOSURE 0.0040 0.0080 ;
  LAYER mcon ;
  RECT -0.0085 -0.0085 0.0085 0.0085 ;
  SPACING 0.0481 BY 0.0481 ;
END L1M1_PR_M

# Minus via rule, upper layer metal is along prefered direction
VIA L1M1_PR_MR DEFAULT
  LAYER mcon ;
  RECT -0.0085 -0.0085 0.0085 0.0085 ;
  LAYER li1 ;
  RECT -0.0085 -0.0085 0.0085 0.0085 ;
  LAYER met1 ;
  RECT -0.0145 -0.0115 0.0145 0.0115 ;
END L1M1_PR_MR

VIARULE L1M1_PR_MR GENERATE
  LAYER li1 ;
  ENCLOSURE 0 0 ;
  LAYER met1 ;
  ENCLOSURE 0.0080 0.0040 ;
  LAYER mcon ;
  RECT -0.0085 -0.0085 0.0085 0.0085 ;
  SPACING 0.0481 BY 0.0481 ;
END L1M1_PR_MR

# Centered via rule, we really do not want to use it
VIA L1M1_PR_C DEFAULT
  LAYER mcon ;
  RECT -0.0085 -0.0085 0.0085 0.0085 ;
  LAYER li1 ;
  RECT -0.0085 -0.0085 0.0085 0.0085 ;
  LAYER met1 ;
  RECT -0.0145 -0.0145 0.0145 0.0145 ;
END L1M1_PR_C

VIARULE L1M1_PR_C GENERATE
  LAYER li1 ;
  ENCLOSURE 0 0 ;
  LAYER met1 ;
  ENCLOSURE 0.0080 0.0080 ;
  LAYER mcon ;
  RECT -0.0085 -0.0085 0.0085 0.0085 ;
  SPACING 0.0481 BY 0.0481 ;
END L1M1_PR_C

