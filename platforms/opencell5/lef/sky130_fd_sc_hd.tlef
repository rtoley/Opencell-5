# Plus via rule, metals are along the prefered direction
VIA M4M5_PR DEFAULT
  LAYER via4 ;
  RECT -0.04 -0.04 0.04 0.04 ;
  LAYER met4 ;
  RECT -0.059 -0.059 0.059 0.059 ;
  LAYER met5 ;
  RECT -0.071 -0.071 0.071 0.071 ;
END M4M5_PR

VIARULE M4M5_PR GENERATE
  LAYER met4 ;
  ENCLOSURE 0.0253 0.0253 ;
  LAYER met5 ;
  ENCLOSURE 0.0414 0.0414 ;
  LAYER via4 ;
  RECT -0.04 -0.04 0.04 0.04 ;
  SPACING 0.2138 BY 0.2138 ;
END M4M5_PR

# Plus via rule, metals are along the non prefered direction
VIA M4M5_PR_R DEFAULT
  LAYER via4 ;
  RECT -0.04 -0.04 0.04 0.04 ;
  LAYER met4 ;
  RECT -0.059 -0.059 0.059 0.059 ;
  LAYER met5 ;
  RECT -0.071 -0.071 0.071 0.071 ;
END M4M5_PR_R

VIARULE M4M5_PR_R GENERATE
  LAYER met4 ;
  ENCLOSURE 0.0253 0.0253 ;
  LAYER met5 ;
  ENCLOSURE 0.0414 0.0414 ;
  LAYER via4 ;
  RECT -0.04 -0.04 0.04 0.04 ;
  SPACING 0.2138 BY 0.2138 ;
END M4M5_PR_R

# Minus via rule, lower layer metal is along prefered direction
VIA M4M5_PR_M DEFAULT
  LAYER via4 ;
  RECT -0.04 -0.04 0.04 0.04 ;
  LAYER met4 ;
  RECT -0.059 -0.059 0.059 0.059 ;
  LAYER met5 ;
  RECT -0.071 -0.071 0.071 0.071 ;
END M4M5_PR_M

VIARULE M4M5_PR_M GENERATE
  LAYER met4 ;
  ENCLOSURE 0.0253 0.0253 ;
  LAYER met5 ;
  ENCLOSURE 0.0414 0.0414 ;
  LAYER via4 ;
  RECT -0.04 -0.04 0.04 0.04 ;
  SPACING 0.2138 BY 0.2138 ;
END M4M5_PR_M

# Minus via rule, upper layer metal is along prefered direction
VIA M4M5_PR_MR DEFAULT
  LAYER via4 ;
  RECT -0.04 -0.04 0.04 0.04 ;
  LAYER met4 ;
  RECT -0.059 -0.059 0.059 0.059 ;
  LAYER met5 ;
  RECT -0.071 -0.071 0.071 0.071 ;
END M4M5_PR_MR

VIARULE M4M5_PR_MR GENERATE
  LAYER met4 ;
  ENCLOSURE 0.0253 0.0253 ;
  LAYER met5 ;
  ENCLOSURE 0.0414 0.0414 ;
  LAYER via4 ;
  RECT -0.04 -0.04 0.04 0.04 ;
  SPACING 0.2138 BY 0.2138 ;
END M4M5_PR_MR

# Centered via rule, we really do not want to use it
VIA M4M5_PR_C DEFAULT
  LAYER via4 ;
  RECT -0.04 -0.04 0.04 0.04 ;
  LAYER met4 ;
  RECT -0.059 -0.059 0.059 0.059 ;
  LAYER met5 ;
  RECT -0.071 -0.071 0.071 0.071 ;
END M4M5_PR_C

VIARULE M4M5_PR_C GENERATE
  LAYER met4 ;
  ENCLOSURE 0.0253 0.0253 ;
  LAYER met5 ;
  ENCLOSURE 0.0414 0.0414 ;
  LAYER via4 ;
  RECT -0.04 -0.04 0.04 0.04 ;
  SPACING 0.2138 BY 0.2138 ;
END M4M5_PR_C
###  end of single via cells   ###

END LIBRARY
