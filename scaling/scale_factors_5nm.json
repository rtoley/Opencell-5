{
  "schema_version": "0.3",
  "version": "0.5.0-5nm",
  "source_pdk": "sky130_fd_sc_hd",
  "target_node": "5nm-class",
  "_note": "opencell-5: statistical 5nm-class deck. Same recipe as opencell-7 (scale sky130 by published-ratio factors); factors tightened one node. NOT sign-off — a representative feel of 5nm for those without foundry access. 5nm-vs-7nm deltas grounded in ~1.8x N5/N7 density and ~1.2-1.3x N5/N7 speed.",

  "corners": {
    "tt": {
      "source": {
        "name": "tt_025C_1v80",
        "voltage": 1.80,
        "temperature": 25.0,
        "lib_filename": "sky130_fd_sc_hd__tt_025C_1v80.lib"
      },
      "target": {
        "name": "tt_0p70v_25c",
        "voltage": 0.70,
        "temperature": 25.0,
        "library_name": "opencell5_tt_0p70v_25c",
        "lib_filename": "opencell5_tt_0p70v_25c.lib"
      },
      "intent": "Typical-typical, 25C. 5nm-class PPA feel. Use for typical-case estimation."
    },
    "ss": {
      "source": {
        "name": "ss_n40C_1v60",
        "voltage": 1.60,
        "temperature": -40.0,
        "lib_filename": "sky130_fd_sc_hd__ss_n40C_1v60.lib"
      },
      "target": {
        "name": "ss_0p65v_125c",
        "voltage": 0.65,
        "temperature": 125.0,
        "library_name": "opencell5_ss_0p65v_125c",
        "lib_filename": "opencell5_ss_0p65v_125c.lib"
      },
      "intent": "Slow-slow, 125C, low voltage. Setup/worst-case fmax. Same SS relabel convention as opencell-7 (sky130 SS numerics, 7nm/5nm hot-corner label)."
    }
  },

  "factors": {
    "delay": {
      "operation": "divide",
      "value": 15.0,
      "range": [13.0, 18.0],
      "applies_to": [
        "cell_rise.values",
        "cell_fall.values",
        "rise_transition.values",
        "fall_transition.values",
        "cell_rise.index_1",
        "cell_fall.index_1",
        "rise_transition.index_1",
        "fall_transition.index_1",
        "lu_table_template.index_1 (when transition-typed)"
      ],
      "citation": "docs/SOURCES.md#S1",
      "summary": "130nm sky130 FO4 ~80-100 ps vs published 5nm FO4 ~5-6 ps; midpoint 15x (vs opencell-7 7nm 12.5x -> 5nm ~1.2x faster)."
    },

    "process_derate": {
      "operation": "multiply",
      "value": 1.5,
      "range": [1.3, 1.5],
      "applies_to": [
        "composes_with_delay",
        "composes_with_setup_hold"
      ],
      "citation": "docs/SOURCES.md#S9",
      "summary": "FinFET OCV-equivalent process derate; published 7-5nm sign-off 1.3-1.5x. Kept at 1.5 (same as opencell-7); N5 is still FinFET-class OCV."
    },

    "area": {
      "operation": "divide",
      "value": 100.0,
      "range": [85.0, 110.0],
      "applies_to": ["cell.area"],
      "citation": "docs/SOURCES.md#S2",
      "summary": "opencell-7 56x (7nm) x 1.79 (N5/N7 density step, ~90->~170 MTr/mm^2) = 100x. sky130 NAND2 ~3.75 um^2 -> 5nm ~0.0375 um^2. Linear sqrt(100)=10.0 (vs 7nm 7.483). Gives oc5 ~1.8x denser than oc7 for a clean one-node correlation."
    },

    "dynamic_power": {
      "operation": "divide",
      "value": 8.0,
      "range": [6.0, 10.0],
      "applies_to": [
        "internal_power.rise_power.values",
        "internal_power.fall_power.values",
        "internal_power.power.values"
      ],
      "citation": "docs/SOURCES.md#S3",
      "summary": "C*V^2 per-switch energy drops further at 5nm; ~8x (vs opencell-7 6.5x)."
    },

    "leakage": {
      "operation": "multiply",
      "value": 25.0,
      "range": [15.0, 35.0],
      "applies_to": [
        "cell.cell_leakage_power",
        "leakage_power.value"
      ],
      "citation": "docs/SOURCES.md#S4",
      "summary": "5nm RVT per-cell leakage above 7nm as density rises; 25x (vs opencell-7 20x)."
    },

    "input_cap": {
      "operation": "divide",
      "value": 5.0,
      "range": [4.0, 6.0],
      "applies_to": [
        "pin.capacitance",
        "pin.rise_capacitance",
        "pin.fall_capacitance",
        "cell_rise.index_2",
        "cell_fall.index_2",
        "rise_transition.index_2",
        "fall_transition.index_2",
        "rise_power.index_2",
        "fall_power.index_2"
      ],
      "citation": "docs/SOURCES.md#S5",
      "summary": "sky130 INV ~2 fF input vs 5nm INV ~0.4 fF; ~5x (vs opencell-7 4x)."
    },

    "setup_hold": {
      "operation": "divide",
      "value": 12.0,
      "range": [8.0, 16.0],
      "applies_to": [
        "rise_constraint.values",
        "fall_constraint.values"
      ],
      "citation": "docs/SOURCES.md#S6",
      "summary": "sky130 FF setup ~50-80 ps vs 5nm FF setup ~4-6 ps; 12x (vs opencell-7 10x). Composes process_derate on top."
    }
  },

  "preserve_unchanged": [
    "library.time_unit",
    "library.voltage_unit",
    "library.current_unit",
    "library.pulling_resistance_unit",
    "library.leakage_power_unit",
    "library.capacitive_load_unit",
    "library.default_*",
    "cell.cell_name",
    "pin.direction",
    "pin.function",
    "pin.clock",
    "timing.related_pin",
    "timing.timing_sense",
    "timing.timing_type",
    "ff.next_state",
    "ff.clocked_on",
    "ff.preset",
    "ff.clear",
    "lu_table_template.*",
    "power_lut_template.*"
  ]
}
